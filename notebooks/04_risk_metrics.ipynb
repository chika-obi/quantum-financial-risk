# ============================================
# CELL 3: VAR AND CVAR FUNCTIONS
# ============================================

print("\n🔧 STEP 2: Defining VaR and CVaR functions...")

def calculate_var(returns, confidence_level=0.95):
    """
    Calculate Value at Risk (VaR)

    VaR is the maximum expected loss at a given confidence level.
    For example, 95% VaR = -2% means there is a 5% chance of losing more than 2%.

    Args:
        returns: Array of returns or prediction errors
        confidence_level: Typically 0.95 or 0.99

    Returns:
        VaR value (negative number represents loss)
    """
    # VaR is the (1-confidence_level) percentile
    var = np.percentile(returns, (1 - confidence_level) * 100)
    return var

def calculate_cvar(returns, confidence_level=0.95):
    """
    Calculate Conditional Value at Risk (CVaR) / Expected Shortfall

    CVaR is the average loss beyond VaR. It captures tail risk.

    Args:
        returns: Array of returns or prediction errors
        confidence_level: Typically 0.95 or 0.99

    Returns:
        CVaR value (negative number represents loss)
    """
    var = calculate_var(returns, confidence_level)
    # CVaR is the mean of returns below VaR
    cvar = returns[returns <= var].mean()
    return cvar

def calculate_all_risk_metrics(errors, confidence_levels=[0.95, 0.99]):
    """
    Calculate VaR and CVaR for multiple confidence levels
    """
    metrics = {}
    for cl in confidence_levels:
        metrics[f'VaR_{int(cl*100)}%'] = calculate_var(errors, cl)
        metrics[f'CVaR_{int(cl*100)}%'] = calculate_cvar(errors, cl)
    return metrics

# Test functions
test_returns = np.random.normal(0, 0.01, 1000)
test_var = calculate_var(test_returns, 0.95)
test_cvar = calculate_cvar(test_returns, 0.95)
print(f"✅ Functions verified: Test VaR(95%) = {test_var:.6f}, CVaR(95%) = {test_cvar:.6f}")

