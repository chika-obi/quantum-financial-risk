# Load original data
X_train = np.load(f'data/processed/{asset_name}_X_train.npy')
X_test = np.load(f'data/processed/{asset_name}_X_test.npy')
y_train = np.load(f'data/processed/{asset_name}_y_train.npy')
y_test = np.load(f'data/processed/{asset_name}_y_test.npy')

with open('data/processed/scalers.pkl', 'rb') as f:
    scalers = pickle.load(f)

# Clean data
imputer = SimpleImputer(strategy='mean')
X_train = imputer.fit_transform(X_train)
X_test = imputer.transform(X_test)

mask_train = ~np.isnan(y_train)
mask_test = ~np.isnan(y_test)
X_train = X_train[mask_train]
y_train = y_train[mask_train]
X_test = X_test[mask_test]
y_test = y_test[mask_test]

# Train Ridge
ridge = Ridge(alpha=1.0)
ridge.fit(X_train, y_train)
ridge_pred_scaled = ridge.predict(X_test)

# Denormalize
scaler_y = scalers[asset_name]['y']
ridge_pred = scaler_y.inverse_transform(ridge_pred_scaled.reshape(-1, 1)).flatten()
