# Quick fix: Check for NaN in S&P 500 and FTSE 100
import numpy as np

for asset_name in ['S&P_500', 'FTSE_100']:
    X = np.load(f'data/processed/{asset_name}_X.npy')
    y = np.load(f'data/processed/{asset_name}_y.npy')
    
    print(f"{asset_name}:")
    print(f"  NaN in X: {np.isnan(X).sum()}")
    print(f"  NaN in y: {np.isnan(y).sum()}")
    
    # Remove NaN rows if any
    if np.isnan(y).sum() > 0:
        valid_idx = ~np.isnan(y)
        X = X[valid_idx]
        y = y[valid_idx]
        np.save(f'data/processed/{asset_name}_X.npy', X)
        np.save(f'data/processed/{asset_name}_y.npy', y)
        print(f"  ✅ Removed NaN rows. New shape: {X.shape}")