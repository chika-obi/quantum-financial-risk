# Cell 1: Install libraries
!pip install yfinance pandas numpy scikit-learn matplotlib -q

import yfinance as yf
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.preprocessing import MinMaxScaler
import os
import pickle
import warnings
warnings.filterwarnings('ignore')

print("✅ Libraries installed and loaded")

# Cell 2: Define assets to download
assets = {
    'SP500': '^GSPC',
    'FTSE100': '^FTSE',
    'EURUSD': 'EURUSD=X',
    'GBPUSD': 'GBPUSD=X'
}

start_date = '2020-01-01'
end_date = '2024-12-31'

print("="*50)
print("DATA DOWNLOAD")
print("="*50)
print(f"Assets: {list(assets.keys())}")
print(f"Period: {start_date} to {end_date}")

# Cell 3: Download data
def download_data(ticker, name):
    print(f"Downloading {name}...")
    data = yf.download(ticker, start=start_date, end=end_date, progress=False)
    data['Return'] = np.log(data['Close'] / data['Close'].shift(1))
    data = data.dropna()
    print(f"  ✅ {len(data)} days")
    return data['Return']

all_returns = {}
for name, ticker in assets.items():
    all_returns[name] = download_data(ticker, name)

# Combine into DataFrame
returns_df = pd.DataFrame(all_returns)
print(f"\n✅ Total dataset: {returns_df.shape[0]} days, {returns_df.shape[1]} assets")
print("\nFirst 5 rows:")
print(returns_df.head())

# Cell 4: Create feature engineering function
def create_features(returns_series, window=5):
    """
    Create features from returns series.

    Features (6 total):
    - 5 lagged returns (t-5 to t-1)
    - 1 rolling volatility (5-day window)

    Target:
    - Next day return (t+1)
    """
    features = []
    targets = []

    for i in range(window, len(returns_series) - 1):
        # Lagged returns
        lagged = returns_series.iloc[i-window:i].values
        # Rolling volatility
        vol = returns_series.iloc[i-window:i].std()
        # Combine
        features.append(np.append(lagged, vol))
        # Target
        targets.append(returns_series.iloc[i+1])

    return np.array(features), np.array(targets)

# Test the function
X_test, y_test = create_features(returns_df['SP500'])
print(f"\n✅ Feature engineering test:")
print(f"  Features shape: {X_test.shape}")
print(f"  Target shape: {y_test.shape}")
print(f"  Features: lag_1, lag_2, lag_3, lag_4, lag_5, volatility")

# Cell 5: Create directories
os.makedirs('data/raw', exist_ok=True)
os.makedirs('data/processed', exist_ok=True)

print("\n✅ Directories created:")
print("  - data/raw/")
print("  - data/processed/")

# Cell 6: Save raw data
returns_df.to_csv('data/raw/asset_returns.csv')
print("\n✅ Raw data saved to data/raw/asset_returns.csv")

# Cell 7: Process each asset
print("\n" + "="*50)
print("PROCESSING ASSETS")
print("="*50)

all_features = {}
all_targets = {}
all_scalers = {}

for asset_name in assets.keys():
    print(f"\nProcessing {asset_name}...")

    # Create features
    X, y = create_features(returns_df[asset_name])

    # Remove any NaN rows
    nan_mask = ~np.isnan(y)
    X = X[nan_mask]
    y = y[nan_mask]

    # Normalize
    scaler_X = MinMaxScaler()
    scaler_y = MinMaxScaler()

    X_scaled = scaler_X.fit_transform(X)
    y_scaled = scaler_y.fit_transform(y.reshape(-1, 1)).flatten()

    # Store
    all_features[asset_name] = X_scaled
    all_targets[asset_name] = y_scaled
    all_scalers[asset_name] = {'X': scaler_X, 'y': scaler_y}

    print(f"  Features: {X_scaled.shape}")
    print(f"  Target range: [{y_scaled.min():.3f}, {y_scaled.max():.3f}]")

# Cell 8: Save processed features and targets
for asset_name in assets.keys():
    np.save(f'data/processed/{asset_name}_X.npy', all_features[asset_name])
    np.save(f'data/processed/{asset_name}_y.npy', all_targets[asset_name])

# Save scalers
with open('data/processed/scalers.pkl', 'wb') as f:
    pickle.dump(all_scalers, f)

print("\n✅ Processed data saved to data/processed/")
print("   - *_X.npy: Features")
print("   - *_y.npy: Targets")
print("   - scalers.pkl: Normalization objects")

# Cell 9: Create train/test splits
split_ratio = 0.8

print("\n" + "="*50)
print("TRAIN/TEST SPLITS")
print("="*50)

for asset_name in assets.keys():
    X = all_features[asset_name]
    y = all_targets[asset_name]

    split_idx = int(len(X) * split_ratio)

    X_train = X[:split_idx]
    X_test = X[split_idx:]
    y_train = y[:split_idx]
    y_test = y[split_idx:]

    # Save splits
    np.save(f'data/processed/{asset_name}_X_train.npy', X_train)
    np.save(f'data/processed/{asset_name}_X_test.npy', X_test)
    np.save(f'data/processed/{asset_name}_y_train.npy', y_train)
    np.save(f'data/processed/{asset_name}_y_test.npy', y_test)

    print(f"{asset_name}: Train {len(X_train)} / Test {len(X_test)}")

# Cell 10: Visualization
fig, axes = plt.subplots(2, 2, figsize=(12, 8))
axes = axes.flatten()

for idx, asset_name in enumerate(assets.keys()):
    y_train = np.load(f'data/processed/{asset_name}_y_train.npy')
    y_test = np.load(f'data/processed/{asset_name}_y_test.npy')

    axes[idx].plot(y_train[:200], label='Train', alpha=0.7, color='blue')
    axes[idx].plot(range(len(y_train), len(y_train)+100), y_test[:100], label='Test', alpha=0.7, color='red')
    axes[idx].set_title(f'{asset_name}')
    axes[idx].set_xlabel('Sample')
    axes[idx].set_ylabel('Normalized Return')
    axes[idx].legend()
    axes[idx].grid(True, alpha=0.3)

plt.suptitle('Train/Test Split Visualization', fontsize=14)
plt.tight_layout()
plt.savefig('data/processed/data_split_visualization.png', dpi=150)
plt.show()

print("\n✅ Visualization saved to data/processed/data_split_visualization.png")

# Cell 11: Summary
print("\n" + "="*50)
print("NOTEBOOK 01 COMPLETE")
print("="*50)
print("\nFiles created:")
print("  📁 data/raw/")
print("     └── asset_returns.csv")
print("  📁 data/processed/")
print("     ├── SP500_X.npy, SP500_y.npy")
print("     ├── FTSE100_X.npy, FTSE100_y.npy")
print("     ├── EURUSD_X.npy, EURUSD_y.npy")
print("     ├── GBPUSD_X.npy, GBPUSD_y.npy")
print("     ├── SP500_X_train.npy, SP500_X_test.npy")
print("     ├── SP500_y_train.npy, SP500_y_test.npy")
print("     ├── (same for all assets)")
print("     ├── scalers.pkl")
print("     └── data_split_visualization.png")
print("\n✅ Ready for Notebook 02: QNN Model |Classical Baseline")