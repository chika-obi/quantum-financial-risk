# Cell 1: Install dependencies
!pip install yfinance pandas numpy scikit-learn matplotlib -q

import yfinance as yf
import numpy as np
import pandas as pd
from sklearn.preprocessing import MinMaxScaler
import os
import pickle
import matplotlib.pyplot as plt
import warnings
warnings.filterwarnings('ignore')

print("✅ Libraries loaded")

# Cell 2: Define assets to download
assets = {
    'S&P_500': '^GSPC',
    'FTSE_100': '^FTSE',
    'EUR_USD': 'EURUSD=X',
    'GBP_USD': 'GBPUSD=X'
}

start_date = '2020-01-01'
end_date = '2024-12-31'

print("Assets:", list(assets.keys()))
print(f"Date range: {start_date} to {end_date}")

# Cell 3: Download data for all assets
def download_asset_data(ticker, name, start, end):
    """Download and process single asset"""
    print(f"Downloading {name} ({ticker})...")
    data = yf.download(ticker, start=start, end=end, progress=False)
    
    # Calculate daily returns
    data['Return'] = np.log(data['Close'] / data['Close'].shift(1))
    data = data.dropna()
    
    print(f"  ✅ {len(data)} days")
    return data['Return']

# Download all assets
all_returns = {}
for name, ticker in assets.items():
    all_returns[name] = download_asset_data(ticker, name, start_date, end_date)

# Combine into one DataFrame
returns_df = pd.DataFrame(all_returns)
print(f"\n✅ Total dataset shape: {returns_df.shape}")
print(returns_df.head())

# Cell 4: Feature engineering function
def create_features(returns_series, window=5):
    """
    Create features from returns series.
    
    Features:
    - Lagged returns (t-1, t-2, t-3, t-4, t-5)
    - Rolling volatility (5-day)
    
    Target:
    - Next day return (t+1)
    """
    features = []
    targets = []
    
    for i in range(window, len(returns_series) - 1):
        # Lagged returns
        lag_features = returns_series.iloc[i-window:i].values
        # Rolling volatility
        vol = returns_series.iloc[i-window:i].std()
        # Combine
        features.append(np.append(lag_features, vol))
        # Target: next day return
        targets.append(returns_series.iloc[i+1])
    
    return np.array(features), np.array(targets)

# Test on S&P 500
X_test, y_test = create_features(returns_df['S&P_500'])
print(f"Features shape: {X_test.shape}")
print(f"Target shape: {y_test.shape}")
print(f"Feature names: ['lag_1', 'lag_2', 'lag_3', 'lag_4', 'lag_5', 'volatility']")

# Cell 5: Process all assets and save
# Create directories if they don't exist
os.makedirs('data/raw', exist_ok=True)
os.makedirs('data/processed', exist_ok=True)

# Save raw returns
returns_df.to_csv('data/raw/asset_returns.csv')
print("✅ Saved raw returns to data/raw/asset_returns.csv")

# Process each asset
all_features = {}
all_targets = {}
all_scalers = {}

for asset_name in assets.keys():
    print(f"\nProcessing {asset_name}...")
    
    # Create features
    X, y = create_features(returns_df[asset_name])
    
    # Normalize features and targets separately
    scaler_X = MinMaxScaler()
    scaler_y = MinMaxScaler()
    
    X_scaled = scaler_X.fit_transform(X)
    y_scaled = scaler_y.fit_transform(y.reshape(-1, 1)).flatten()
    
    # Store
    all_features[asset_name] = X_scaled
    all_targets[asset_name] = y_scaled
    all_scalers[asset_name] = {'X': scaler_X, 'y': scaler_y}
    
    print(f"  Features: {X_scaled.shape}")
    print(f"  Target range: [{y_scaled.min():.3f}, {y_scaled.max():.3f}]")

# Cell 6: Save processed data
# Save features and targets
for asset_name in assets.keys():
    np.save(f'data/processed/{asset_name}_X.npy', all_features[asset_name])
    np.save(f'data/processed/{asset_name}_y.npy', all_targets[asset_name])

# Save scalers
with open('data/processed/scalers.pkl', 'wb') as f:
    pickle.dump(all_scalers, f)

print("\n✅ All processed data saved to data/processed/")
print("   - *_X.npy: Feature arrays")
print("   - *_y.npy: Target arrays")
print("   - scalers.pkl: MinMaxScaler objects")

# Cell 7: Train-test split
split_ratio = 0.8

for asset_name in assets.keys():
    X = all_features[asset_name]
    y = all_targets[asset_name]
    
    split_idx = int(len(X) * split_ratio)
    
    X_train = X[:split_idx]
    X_test = X[split_idx:]
    y_train = y[:split_idx]
    y_test = y[split_idx:]
    
    # Save splits
    np.save(f'data/processed/{asset_name}_X_train.npy', X_train)
    np.save(f'data/processed/{asset_name}_X_test.npy', X_test)
    np.save(f'data/processed/{asset_name}_y_train.npy', y_train)
    np.save(f'data/processed/{asset_name}_y_test.npy', y_test)
    
    print(f"{asset_name}: Train {len(X_train)} / Test {len(X_test)}")

print("\n✅ Train-test splits saved")

# Cell 8: Quick visualization of processed data
fig, axes = plt.subplots(2, 2, figsize=(12, 8))
axes = axes.flatten()

for idx, asset_name in enumerate(assets.keys()):
    y_train = np.load(f'data/processed/{asset_name}_y_train.npy')
    y_test = np.load(f'data/processed/{asset_name}_y_test.npy')
    
    axes[idx].plot(y_train[:200], label='Train', alpha=0.7)
    axes[idx].plot(range(len(y_train), len(y_train)+100), y_test[:100], label='Test', alpha=0.7)
    axes[idx].set_title(f'{asset_name} - Normalized Returns')
    axes[idx].set_xlabel('Sample')
    axes[idx].set_ylabel('Normalized Return')
    axes[idx].legend()
    axes[idx].grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('data/processed/data_split_visualization.png', dpi=150)
plt.show()

print("✅ Visualization saved to data/processed/data_split_visualization.png")

# Cell 9: Summary
print("\n" + "="*50)
print("DATA PREPARATION COMPLETE")
print("="*50)
print("\nFiles created:")
print("  📁 data/raw/")
print("     └── asset_returns.csv")
print("  📁 data/processed/")
print("     ├── S&P_500_X.npy, S&P_500_y.npy")
print("     ├── FTSE_100_X.npy, FTSE_100_y.npy")
print("     ├── EUR_USD_X.npy, EUR_USD_y.npy")
print("     ├── GBP_USD_X.npy, GBP_USD_y.npy")
print("     ├── *_train.npy, *_test.npy (splits)")
print("     ├── scalers.pkl")
print("     └── data_split_visualization.png")
print("\n✅ Ready for Notebook 02: QNN Model")